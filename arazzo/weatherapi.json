    "/alerts.json": {
      "get": {
        "operationId": "getAlerts",
        "summary": "Get weather alerts",
        "description": "Get severe weather alerts for a location.",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          }
        ],
        "responses": {
