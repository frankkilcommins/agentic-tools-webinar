              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/marine.json": {
      "get": {
        "operationId": "getMarineWeather",
        "summary": "Get marine weather",
        "description": "Get marine and sailing weather data including tide, swell, wave, and water temperature.",
        "tags": [
          "Marine"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          },
          {
            "name": "days",
            "in": "query",
            "description": "Number of days of marine forecast (1-7)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 7
            }
          },
          {
            "name": "dt",
            "in": "query",
            "description": "Specific date (yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "hour",
            "in": "query",
            "description": "Restrict to specific hour (0-23)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/LangParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with marine weather data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarineResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
