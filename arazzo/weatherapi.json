                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sports.json": {
      "get": {
        "operationId": "getSports",
        "summary": "Get sports events weather",
        "description": "Get upcoming sports events and their weather conditions including football, cricket, and golf.",
        "tags": [
          "Sports"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          }
        ],
        "responses": {
