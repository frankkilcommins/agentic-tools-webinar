{
  "openapi": "3.0.3",
  "info": {
    "title": "WeatherAPI",
    "description": "Weather API providing realtime weather, forecast, history, future weather, astronomy, geolocation, time zone, sports, marine, and air quality data. Supports JSON and XML response formats.",
    "version": "1.0.0",
    "contact": {
      "name": "WeatherAPI",
      "url": "https://www.weatherapi.com"
    },
    "x-jentic-source-url": "https://www.weatherapi.com/"
  },
  "servers": [
    {
      "url": "https://api.weatherapi.com/v1",
      "description": "WeatherAPI v1"
    }
  ],
  "paths": {
    "/current.json": {
      "get": {
        "operationId": "getRealtimeWeather",
        "summary": "Get realtime weather",
        "description": "Get current weather data for a location. Returns current condition, temperature, wind, pressure, precipitation, humidity, cloud, feels like, visibility, UV index, and air quality data.",
        "tags": [
          "Realtime"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          },
          {
            "name": "aqi",
            "in": "query",
            "description": "Enable/disable air quality data (yes or no)",
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ],
              "default": "no"
            }
          },
          {
            "$ref": "#/components/parameters/LangParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with current weather data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RealtimeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - API key not provided or invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - API key does not have access to this resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/forecast.json": {
      "get": {
        "operationId": "getForecastWeather",
        "summary": "Get forecast weather",
        "description": "Get weather forecast for up to 14 days. Includes hourly forecast, daily forecast, astronomy, and optionally alerts and air quality data.",
        "tags": [
          "Forecast"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          },
          {
            "name": "days",
            "in": "query",
            "required": true,
            "description": "Number of days of forecast (1-14)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 14
            }
          },
          {
            "name": "dt",
            "in": "query",
            "description": "Specific date for forecast (yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "hour",
            "in": "query",
            "description": "Restrict output to specific hour of the day (0-23)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 23
            }
          },
          {
            "name": "aqi",
            "in": "query",
            "description": "Enable/disable air quality data",
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ],
              "default": "no"
            }
          },
          {
            "name": "alerts",
            "in": "query",
            "description": "Enable/disable weather alerts",
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ],
              "default": "no"
            }
          },
          {
            "$ref": "#/components/parameters/LangParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with forecast data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/history.json": {
      "get": {
        "operationId": "getHistoryWeather",
        "summary": "Get historical weather",
        "description": "Get historical weather data for a location on a specific date.",
        "tags": [
          "History"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          },
          {
            "name": "dt",
            "in": "query",
            "required": true,
            "description": "Date for historical data (yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_dt",
            "in": "query",
            "description": "End date for date range (yyyy-MM-dd)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "hour",
            "in": "query",
            "description": "Restrict to specific hour (0-23)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/LangParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with historical data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/future.json": {
      "get": {
        "operationId": "getFutureWeather",
        "summary": "Get future weather",
        "description": "Get weather forecast for 14 to 300 days from today.",
        "tags": [
          "Future"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          },
          {
            "name": "dt",
            "in": "query",
            "required": true,
            "description": "Future date (yyyy-MM-dd, 14-300 days from today)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "$ref": "#/components/parameters/LangParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with future weather data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search.json": {
      "get": {
        "operationId": "searchLocations",
        "summary": "Search or autocomplete locations",
        "description": "Search for locations by name, postcode, IP address, or lat/lon. Returns matching locations for autocomplete.",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/QueryParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with matching locations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchLocation"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/astronomy.json": {
      "get": {
        "operationId": "getAstronomy",
