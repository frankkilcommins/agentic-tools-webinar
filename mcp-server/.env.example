# Weekend Getaway MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# The MCP server reads these at startup.

# WeatherAPI.com API key (free tier: https://www.weatherapi.com/signup.aspx)
WEATHER_API_KEY=your_weatherapi_key_here

# liteapi.travel API key — use the sandbox key for demos (prefix: sand_)
# Get yours at https://app.liteapi.travel
LITEAPI_KEY=sand_your_liteapi_sandbox_key_here

# Google OAuth2 Bearer token with calendar scope
# Obtain via: https://developers.google.com/calendar/api/quickstart/nodejs
# Or use the OAuth playground: https://developers.google.com/oauthplayground
GOOGLE_CALENDAR_TOKEN=your_google_oauth_bearer_token_here
